{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@/*": ["../src/*"]
    },
    "baseUrl": ".."
  },
  "include": ["./**/*.ts"],
  "exclude": ["../node_modules"]
}
