rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Usuarios: Cada usuario puede leer y escribir solo su propio perfil
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 2. Productos: Cualquiera puede leerlos (catálogo público), pero solo administradores (o nadie desde el cliente) pueden modificarlos
    match /productos/{productId} {
      allow read: if true;
      allow write: if false; // Modificaciones solo desde consola o Admin SDK
    }

    // 3. Setups Guardados: Los usuarios autenticados pueden crear y ver/modificar sus propios setups
    match /setups_guardados/{setupId} {
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.usuarioId == request.auth.uid;
    }
  }
}
